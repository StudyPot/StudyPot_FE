{
  "googleLoginRequest": {
    "authorizationCode": "google-authorization-code",
    "redirectUri": "https://app.studypot.example/auth/callback",
    "codeVerifier": "pkce-code-verifier"
  },
  "googleLoginResponse": {
    "accessToken": "mock-access-token",
    "refreshToken": "mock-refresh-token",
    "tokenType": "Bearer",
    "expiresIn": 3600,
    "user": {
      "id": "018f7a4e-0000-7000-9000-000000000001",
      "email": "user@example.com",
      "nickname": "user1"
    }
  },
  "refreshRequest": {
    "refreshToken": "mock-refresh-token"
  },
  "refreshResponse": {
    "accessToken": "mock-access-token-refreshed",
    "refreshToken": "mock-refresh-token-rotated",
    "tokenType": "Bearer",
    "expiresIn": 3600,
    "user": {
      "id": "018f7a4e-0000-7000-9000-000000000001",
      "email": "user@example.com",
      "nickname": "user1"
    }
  },
  "logoutRequest": {
    "refreshToken": "mock-refresh-token"
  }
}
