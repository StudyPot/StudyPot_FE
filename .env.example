# API base URL (e.g. https://studypot.rumiclean.com/api/v1)
# Leave empty to use the Vite dev proxy (VITE_API_PROXY_TARGET must be set)
VITE_API_BASE_URL=

# Proxy target for local dev server (used when VITE_API_BASE_URL is not set)
VITE_API_PROXY_TARGET=http://localhost:8080

# Enable MSW (Mock Service Worker) — set to "true" to use mocked API responses
VITE_ENABLE_MSW=false
